    {
      "id": "step-6-migrations",
      "title": "Database Migrations",
      "description": "Database migrations are append-only and timestamped — read them in order to understand schema evolution. The first migration lays the user, OAuth, and session tables. The next adds the core repository data model. Collaboration follows, introducing issues, pull requests, and reviews. Later migrations add the dashboard, repository imports, archives, and pull request tooling.",
      "estimatedTime": 120,
      "focusDirectory": "crates/api/migrations",
      "colorMode": "git"
    },

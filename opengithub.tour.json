{
  "id": "opengithub-onboarding",
  "title": "opengithub — Codebase Tour",
  "description": "An autonomous GitHub clone built on a Rust backend and a Next.js frontend. This tour walks through the dual-stack layout, authentication, domain logic, database migrations, and frontend.",
  "version": "1.0.0",
  "audience": "New Contributors",
  "prerequisites": [
    "Comfort reading Rust and TypeScript",
    "Familiarity with REST APIs and Next.js app router"
  ],
  "steps": [
    {
      "id": "step-1-overview",
      "title": "Project Overview",
      "description": "opengithub is a GitHub.com clone with a Rust backend and a Next.js frontend, scaffolded by an autonomous build loop. This first view shows the full codebase — note the two top-level worlds, one for the Rust workspace and one for the frontend application.",
